<?xml version="1.0" encoding="utf-8"?>
<Defs>

<!-- Hellfire -->
	<HediffDef>
		<defName>Seg_OA_HellfireBurns</defName>
		<label>Hellfire acid</label>
		<description>A potent bio-acidic toxin is wreaking havoc on this target's insides.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>600~600</disappearsAfterTicks>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath" />
			<li Class="seg.HediffCompProperties_RandomDamage">
				<intervalTicks>60</intervalTicks>
				<amount>5~10</amount>
				<type>AcidBurn</type>
			</li>
		</comps>
	</HediffDef>

	<ThingDef ParentName="BaseBullet">
		<defName>Seg_OA_Bullet_Hellfire</defName>
		<label>Hellfire round</label>
		<description>A round filled with virulent bio-acidic toxins which can turn a target into melted ash from the inside out.</description>
		<uiIconPath>UI/Projectile/Seg_OA_UI_Hellfire</uiIconPath>
		<graphicData>
			<texPath>Things/Projectile/Seg_OA_Hellfire</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>.65</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Seg_OA_HellfireDamage</damageDef>
			<damageAmountBase>20</damageAmountBase>
			<stoppingPower>.5</stoppingPower>
		<speed>90</speed>
		</projectile>
		<recipeMaker>
			<!--researchPrerequisite>Seg_COTO_TechGuardAdvanced</researchPrerequisite-->
		</recipeMaker>
		<costList>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<modExtensions>
			<li Class="Core40k.DefModExtension_AmmoChanger">
				<effectiveRange>55.9</effectiveRange>
				<warmupTime>1.5</warmupTime>
				<shotsPerBurst>1</shotsPerBurst>
			</li>
		</modExtensions>
	</ThingDef>


<!-- Micromelta -->
	<ThingDef ParentName="BaseBullet">
		<defName>Seg_OA_Bullet_Micromelta</defName>
		<label>Micromelta round</label>
		<description>A round tipped with a miniaturised melta charge, able to destroy even the toughest materials and armour.</description>
		 <thingClass>Projectile_Explosive</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Seg_OA_Micromelta</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>.65</drawSize>
		</graphicData>
		<uiIconPath>UI/Projectile/Seg_OA_UI_Micromelta</uiIconPath>
		<projectile>
			<damageDef>Seg_OA_Micromelta_Damage</damageDef>
			<damageAmountBase>25</damageAmountBase>
			<stoppingPower>.5</stoppingPower>
			<explosionRadius>1.1</explosionRadius>
            <speed>60</speed>
			<explosionEffect>Power_Cell_Burning</explosionEffect>
		<speed>750</speed>
		</projectile>
		<costList>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<modExtensions>
			<li Class="Core40k.DefModExtension_AmmoChanger">
				<effectiveRange>31.5</effectiveRange>
				<warmupTime>3</warmupTime>
				<shotsPerBurst>1</shotsPerBurst>
			</li>
		</modExtensions>
	</ThingDef>

<!-- Shield breaker -->
	<ThingDef ParentName="BaseBullet">
		<defName>Seg_OA_Bullet_ShieldBreaker</defName>
		<label>Shield-Breaker round</label>
		<uiIconPath>UI/Projectile/Seg_OA_UI_ShieldBreaker</uiIconPath>
		<description>A round designed to explosively overload any void or energy shields it makes contact with, rendering the shield useless for the near future and damaging anything nearby.</description>
		<graphicData>
			<texPath>Things/Projectile/Seg_OA_ShieldBreaker</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>.65</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>20</damageAmountBase>
			<stoppingPower>.5</stoppingPower>
		<speed>90</speed>
		</projectile>
		<costList>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<thingClass>seg.Projectile_ShieldBreaker</thingClass>
		<modExtensions>
			<li Class="Core40k.DefModExtension_AmmoChanger">
				<effectiveRange>55.9</effectiveRange>
				<warmupTime>1.5</warmupTime>
				<shotsPerBurst>1</shotsPerBurst>
			</li>
		</modExtensions>
	</ThingDef>

<!-- Turbo penetrator -->
	<VEF.Weapons.ExpandableProjectileDef ParentName="BaseBullet">
		<defName>Seg_OA_Bullet_TurboPenetrator</defName>
		<label>Turbo-Penetrator round</label>
		<totalSizeScale>.65</totalSizeScale>
		<uiIconPath>UI/Projectile/Seg_OA_UI_TurboPenetrator</uiIconPath>
		<description>A round with a two-stage explosive charge to punch a secondary round through even the thickest armour, and often anything standing behind it as well.</description>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>28</damageAmountBase>
			<armorPenetrationBase>2</armorPenetrationBase>
			<stoppingPower>4</stoppingPower>
			<speed>750</speed>
		</projectile>
		<thingClass>VEF.Weapons.GaussProjectile</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Seg_OA_TurboPenetratorFadeIn</texPath>
			<texPathFadeOut>Things/Projectile/Seg_OA_TurboPenetratorFadeOut</texPathFadeOut>
		</graphicData>
		<reachMaxRangeAlways>true</reachMaxRangeAlways>
		<minDistanceToAffect>4.9</minDistanceToAffect>
		<drawOffscreen>true</drawOffscreen>
		<lifeTimeDuration>50</lifeTimeDuration>
		<widthScaleFactor>0.10</widthScaleFactor>
		<heightScaleFactor>1</heightScaleFactor>
		<startingPositionOffset>(0,0,-1)</startingPositionOffset>
		<totalSizeScale>0.8</totalSizeScale>
		<tickFrameRate>2</tickFrameRate>
		<finalTickFrameRate>2</finalTickFrameRate>
		<tickDamageRate>5</tickDamageRate>
		<dealsDamageOnce>true</dealsDamageOnce>
		<disableVanillaDamageMethod>true</disableVanillaDamageMethod>
		<stopWhenHit>false</stopWhenHit>
		<stopWhenHitAt>
			<li>CollapsedRocks</li>
			<li>MineableSteel</li>
			<li>MineableSilver</li>
			<li>MineableGold</li>
			<li>MineableUranium</li>
			<li>MineablePlasteel</li>
			<li>MineableJade</li>
			<li>MineableComponentsIndustrial</li>
			<li>RaisedRocks</li>
			<li>Sandstone</li>
			<li>SmoothedSandstone</li>
			<li>Granite</li>
			<li>SmoothedGranite</li>
			<li>Limestone</li>
			<li>SmoothedLimestone</li>
			<li>Slate</li>
			<li>SmoothedSlate</li>
			<li>Marble</li>
			<li>SmoothedMarble</li>
		</stopWhenHitAt>
	</VEF.Weapons.ExpandableProjectileDef>
</Defs>