		<modExtensions>
			<li Class="VEF.Things.ThingDefExtension">
				<weaponCarryDrawOffsets>
					<south>
						<drawOffset>(0, 0, -0.07)</drawOffset>
					</south>
				</weaponCarryDrawOffsets>
			</li>
		</modExtensions>

		<tools Inherit="False">
			<li>
				<label>grip</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>1.6</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
