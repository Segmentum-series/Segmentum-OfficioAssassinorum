	<!-- Vindicare Mask -->
		<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_PsykerHelm</defName>
		<label>psyker helm</label>
		<description>This specially constructed helm serves to strengthen and regulate the warp-touched power of the psyker, making it easier for them to tap into their psykanic talents without being overwhelmed or losing control.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/PsykerHelm/Seg_WOTV_PsykerHelm</texPath>
		</graphicData>

		<equippedStatOffsets>
			<PsychicSensitivity>1</PsychicSensitivity>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>14000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>2.2</Mass>
			<ArmorRating_Sharp>0.55</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.75</ArmorRating_Heat>
			<Insulation_Cold>14.4</Insulation_Cold>
			<Insulation_Heat>20</Insulation_Heat>
			<DecompressionResistance MayRequire="kentington.saveourship2">0.85</DecompressionResistance>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.85</VacuumResistance>
		</statBases>

		<costList>
			<Plasteel>25</Plasteel>
			<ComponentSpacer>1</ComponentSpacer>
		</costList>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>UpperHead</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/PsykerHelm/Seg_WOTV_PsykerHelm</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>ComplexClothing</li>
				<li>Seg_WOTV_SpecialistApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		
